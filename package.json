{
  "name": "neighbrd",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @neighbrd/db generate",
    "db:migrate": "pnpm --filter @neighbrd/db migrate",
    "db:seed": "pnpm --filter @neighbrd/db seed",
    "db:studio": "pnpm --filter @neighbrd/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  }
}
